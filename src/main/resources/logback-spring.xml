<?xml version="1.0" encoding="UTF-8"?>
<configuration>
	<!--
		说明：
		1) 采用 LogstashEncoder 将日志输出为 JSON 结构化格式，便于接入 ELK/Loki 等日志平台，支持字段检索与聚合
		2) 控制台输出（ConsoleAppender）即可满足开发/测试场景；生产可按需追加异步/文件/远端 Appender
		3) 结合应用内的 MDC（如 requestId），日志平台可实现按请求链路精确定位
		原理简述：
		- Logback 通过 Encoder 将日志事件序列化；LogstashEncoder 会输出含 @timestamp、logger_name、level 等标准字段的 JSON
	-->
	<!-- 开发环境控制台日志：彩色可读格式 -->
	<appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
		<encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
			<!-- 说明：使用彩色模式输出，%highlight 会根据日志级别自动着色，%cyan/magenta 等为固定颜色 -->
			<pattern>%d{HH:mm:ss.SSS} %highlight(%-5level) %cyan(%logger{36}) - %msg%n</pattern>
		</encoder>
	</appender>

	<!-- 生产环境日志：JSON 结构化格式（便于日志平台解析） -->
	<appender name="STDOUT-PROD" class="ch.qos.logback.core.ConsoleAppender">
		<encoder class="net.logstash.logback.encoder.LogstashEncoder"/>
	</appender>

	<!-- 默认使用彩色控制台日志（开发环境） -->
	<springProfile name="!prod">
		<root level="INFO">
			<appender-ref ref="STDOUT"/>
		</root>
	</springProfile>

	<!-- 生产环境使用 JSON 结构化日志 -->
	<springProfile name="prod">
		<root level="INFO">
			<appender-ref ref="STDOUT-PROD"/>
		</root>
	</springProfile>
</configuration>