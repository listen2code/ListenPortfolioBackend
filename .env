# Generated from env-config.json for local environment
DATABASE_URL=jdbc:mysql://db:3306/portfolio?useSSL=false&serverTimezone=Asia/Tokyo&allowPublicKeyRetrieval=true
DATABASE_USERNAME=root
DATABASE_PASSWORD=Ls-88888888
JAVA_OPTS=-Xms256m -Xmx512m -XX:+UseG1GC -XX:MaxGCPauseMillis=200
AWS_REGION=ap-northeast-1
ENVIRONMENT=local
APP_PORT=8080
PROMETHEUS_PORT=9090
PROMETHEUS_HOST=localhost
PROMETHEUS_TARGET_HOST=host.docker.internal
PROMETHEUS_SCRAPE_INTERVAL=10s
PROMETHEUS_SCRAPE_TIMEOUT=5s
PROMETHEUS_GLOBAL_INTERVAL=15s
PROMETHEUS_EVAL_INTERVAL=15s
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin123
GRAFANA_DOMAIN=localhost
GRAFANA_ROOT_URL=http://localhost:3000
GRAFANA_FOLDER=
GRAFANA_UPDATE_INTERVAL=10
GRAFANA_DASHBOARDS_PATH=/var/lib/grafana/dashboards
PROMETHEUS_RETENTION=200h
REDIS_PORT=6379

# ===================================================================
# 邮件服务配置（必需）
# ===================================================================
# SMTP 服务器地址
# Gmail: smtp.gmail.com
# QQ: smtp.qq.com
# 163: smtp.163.com
MAIL_HOST=smtp.gmail.com

# SMTP 端口
# TLS: 587
# SSL: 465
MAIL_PORT=587

# 发件人邮箱
MAIL_USERNAME=your-email@gmail.com

# 邮箱密码或应用专用密码
# Gmail 用户必须使用应用专用密码，不能使用账号密码
# 生成方法：Google 账号 → 安全性 → 两步验证 → 应用专用密码
MAIL_PASSWORD=your-app-password

# ===================================================================
# 前端配置
# ===================================================================
# 前端应用地址，用于生成密码重置链接
FRONTEND_URL=http://localhost:3000

# ===================================================================
# 密码重置配置
# ===================================================================
# Token 有效期（秒），默认 3600 = 1 小时
PASSWORD_RESET_TOKEN_EXPIRATION=3600
