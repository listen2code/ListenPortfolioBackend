# ===================================================================
# Docker Compose 环境变量模板
# ===================================================================
# 使用方式：复制为 .env 并填入真实值
#   cp .env.example .env
# 注意：.env 已在 .gitignore 中，不会提交到 Git
# ===================================================================

# 数据库凭据
DB_USERNAME=root
DB_PASSWORD=your-db-password

# JWT 密钥（生产环境必须更换为强随机字符串，至少32字符）
JWT_SECRET=your-super-strong-secret-key-that-is-at-least-256-bits-long

# 邮件服务（Gmail 应用专用密码）
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# JVM 参数（可选，已有默认值）
# JAVA_OPTS=-Xms256m -Xmx512m -XX:+UseG1GC -XX:MaxGCPauseMillis=200
