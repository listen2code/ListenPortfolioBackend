{
  "app_url": "http://localhost:8080",
  "app_name": "portfolio-app",
  "aws_region": "ap-northeast-1",
  "description": "Portfolio application environment configuration",
  
  "database": {
    "local": {
      "url": "jdbc:mysql://db:3306/portfolio?useSSL=false&serverTimezone=Asia/Tokyo&allowPublicKeyRetrieval=true",
      "username": "root",
      "password": "Ls-88888888"
    },
    "test": {
      "url": "jdbc:mysql://test-db.xxx.com:3306/portfolio?useSSL=false&serverTimezone=Asia/Tokyo&allowPublicKeyRetrieval=true",
      "username": "portfolio_user",
      "password": "your_test_password"
    },
    "staging": {
      "url": "jdbc:mysql://staging-db.xxx.com:3306/portfolio?useSSL=false&serverTimezone=Asia/Tokyo&allowPublicKeyRetrieval=true",
      "username": "portfolio_user",
      "password": "your_staging_password"
    },
    "prod": {
      "url": "jdbc:mysql://prod-db.xxx.com:3306/portfolio?useSSL=true&serverTimezone=Asia/Tokyo&allowPublicKeyRetrieval=true",
      "username": "portfolio_user",
      "password": "your_prod_password"
    }
  },
  
  "jvm": {
    "local": "-Xms256m -Xmx512m -XX:+UseG1GC -XX:MaxGCPauseMillis=200",
    "test": "-Xms512m -Xmx1024m -XX:+UseG1GC -XX:MaxGCPauseMillis=200",
    "staging": "-Xms512m -Xmx1024m -XX:+UseG1GC -XX:MaxGCPauseMillis=200",
    "prod": "-Xms1024m -Xmx2048m -XX:+UseG1GC -XX:MaxGCPauseMillis=200"
  },
  
  "ports": {
    "app": "8080",
    "database": "3307",
    "prometheus": "9090",
    "grafana": "3000"
  },
  
  "prometheus": {
    "retention": "200h",
    "host": "localhost",
    "target_host": "host.docker.internal",
    "scrape_interval": "10s",
    "scrape_timeout": "5s",
    "global_interval": "15s",
    "eval_interval": "15s"
  },
  
  "grafana": {
    "user": "admin",
    "password": "admin123",
    "folder": "",
    "update_interval": "10",
    "dashboards_path": "/var/lib/grafana/dashboards",
    "local": {
      "domain": "localhost",
      "root_url": "http://localhost:3000"
    },
    "test": {
      "domain": "test.your-domain.com",
      "root_url": "http://test.your-domain.com:3000"
    },
    "staging": {
      "domain": "staging.your-domain.com",
      "root_url": "http://staging.your-domain.com:3000"
    },
    "prod": {
      "domain": "prod.your-domain.com",
      "root_url": "https://prod.your-domain.com:3000"
    }
  }
}
